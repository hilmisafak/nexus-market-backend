            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{buyerPassword}}\",\n  \"firstName\": \"Alici\",\n  \"lastName\": \"Bir\",\n  \"role\": \"BUYER\"\n}"

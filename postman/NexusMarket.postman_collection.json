    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product (Seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response?.data?._id) {",
                  "  pm.collectionVariables.set('productId', response.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Gaming Laptop\",\n  \"description\": \"RTX ekran kartli performans laptop\",\n  \"category\": \"electronics\",\n  \"price\": 59999,\n  \"stock\": 5,\n  \"attributes\": {\n    \"cpu\": \"Intel i7\",\n    \"ram\": \"32GB\",\n    \"storage\": \"1TB SSD\"\n  },\n  \"images\": [\n    \"https://example.com/laptop.jpg\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?category=electronics&minPrice=1000&maxPrice=80000&rating=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "electronics"
                },
                {
                  "key": "minPrice",
                  "value": "1000"
                },
                {
                  "key": "maxPrice",
                  "value": "80000"
                },
                {
                  "key": "rating",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{productId}}"
              ]
            }
          }
        },
        {
          "name": "Update Product (Seller)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {

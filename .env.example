PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/nexusmarket
MONGO_URI=mongodb://localhost:27017/nexusmarket
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-another-strong-secret
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=nm_refresh_token
PAYMENT_WEBHOOK_SECRET=replace-with-a-webhook-signing-secret
PAYMENT_WEBHOOK_TOLERANCE_SEC=300
DEFAULT_TAX_RATE_PERCENT=20
DEFAULT_SHIPPING_FEE=39.9
AUDIT_LOG_SIGNING_SECRET=replace-with-a-strong-audit-signing-secret

# Production: virgulle ayir (ornek: https://app.ornek.com,http://localhost:5173)
CORS_ORIGIN=

# JSON body limiti (ornek: 100kb, 1mb)
JSON_BODY_LIMIT=100kb
